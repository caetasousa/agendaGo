# Variáveis de PRODUÇÃO — copie para .env no host e preencha.
# Consumido por docker-compose.prod.yml.
#
#   cp .env.prod.example .env   &&   nano .env
#   docker compose -f docker-compose.prod.yml up -d --build

# ── Domínio público ────────────────────────────────────────────────────────
# O hostname que aponta para o IP do host (ex.: um subdomínio grátis do
# DuckDNS). O Caddy pega o certificado HTTPS para ele automaticamente. NÃO use
# http:// nem barra final — só o host.
DOMINIO=agendago.duckdns.org

# ── Banco de dados (Postgres interno ao compose) ───────────────────────────
POSTGRES_DB=agendago
POSTGRES_USER=agendago
# Gere uma senha forte, ex.: openssl rand -base64 24
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# ── Admin semeado no boot (moderação) ──────────────────────────────────────
ADMIN_EMAIL=admin@seudominio.com
# Segredo forte — é a chave do painel de moderação. openssl rand -base64 24
ADMIN_SENHA=troque-por-uma-senha-forte

# ── Rate limiting (tetos por IP/minuto) ────────────────────────────────────
# MANTENHA > 0 em produção: protege contra brute-force de login/token e
# rajadas que estouram a CPU do hashing de senha.
RATE_LIMIT_LOGIN_POR_MINUTO=10
RATE_LIMIT_CONVIDADO_POR_MINUTO=10

# ── Envio de email (ex.: Brevo) ────────────────────────────────────────────
# Vazio desliga o envio (emails só são logados). Veja docs/producao.md.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
# IMPORTANTE: o remetente NÃO pode ser @gmail/@outlook/@yahoo — o DMARC deles
# faz o email cair em spam ou ser rejeitado, pois quem envia é o Brevo. Use um
# remetente verificado no provedor.
EMAIL_REMETENTE=nao-responda@seudominio.com
EMAIL_REMETENTE_NOME=agendaGo
# Onde caem as respostas dos usuários (opcional): seu email pessoal.
EMAIL_REPLY_TO=

# ── Login social com Google ────────────────────────────────────────────────
# Vazio desliga o recurso (rotas e botão somem). Credenciais no Google Cloud
# Console (tipo "Web application"). GOOGLE_REDIRECT_URL deve ser exatamente a
# URL de callback registrada lá — em produção, https://SEU_DOMINIO/auth/google/callback.
# O escopo pedido (login) sai do modo Testing sem verificação do app; se
# passar de 100 usuários de teste, o Google exige um processo de verificação.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://seudominio.com/auth/google/callback
