# Copie para .env e ajuste os valores. Consumido pelo docker-compose.yml.

# Banco de dados (Postgres)
POSTGRES_DB=agendago
POSTGRES_USER=agendago
POSTGRES_PASSWORD=troque-esta-senha

# Admin semeado no boot da API (moderação). Troque em produção.
ADMIN_EMAIL=admin@agendago.dev
ADMIN_SENHA=troque-esta-senha

# Rate limiting por IP por minuto (0 desliga; sem a variável vale o padrão 10).
# Em dev deixe 0 — os testes e2e fazem dezenas de logins do mesmo IP.
RATE_LIMIT_LOGIN_POR_MINUTO=10
RATE_LIMIT_CONVIDADO_POR_MINUTO=10

# Envio de email (recuperação de senha e notificações de agendamento).
# Em dev os valores abaixo já apontam para o Mailpit do docker-compose
# (UI em http://localhost:8025) — nenhum email real é enviado.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=false
EMAIL_REMETENTE=nao-responda@agendago.dev
EMAIL_REMETENTE_NOME=agendaGo
# Endereço de resposta (opcional). Deixe as respostas dos usuários caírem no
# seu email pessoal, mesmo que o remetente seja um endereço neutro.
EMAIL_REPLY_TO=

# Login social com Google. Vazio desliga o recurso (rotas e botão somem).
# Crie as credenciais no Google Cloud Console (tipo "Web application"):
# GOOGLE_REDIRECT_URL deve ser exatamente a URL de callback registrada lá,
# ex.: http://localhost:8080/auth/google/callback em desenvolvimento.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Em produção, troque pelas credenciais SMTP do provedor (ex.: Brevo):
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=<login SMTP da conta Brevo>
# SMTP_PASSWORD=<chave SMTP gerada no Brevo>
# SMTP_STARTTLS=true
# IMPORTANTE: NÃO use um @gmail.com/@yahoo.com/@outlook.com como remetente — o
# DMARC estrito desses provedores faz o email ser rejeitado ou cair em spam,
# pois quem envia é o Brevo, não o Google. Use um sender verificado no Brevo
# (ex.: um endereço de um domínio próprio com DKIM, ou o remetente que o Brevo
# oferece). Coloque seu email pessoal em EMAIL_REPLY_TO para receber respostas.
# EMAIL_REMETENTE=<remetente verificado no Brevo, NÃO um @gmail.com>
# EMAIL_REMETENTE_NOME=agendaGo
# EMAIL_REPLY_TO=<seu email pessoal para respostas>
