# Copie para .env e ajuste os valores. Consumido pelo docker-compose.yml.

# Banco de dados (Postgres)
POSTGRES_DB=agendago
POSTGRES_USER=agendago
POSTGRES_PASSWORD=troque-esta-senha

# Admin semeado no boot da API (moderação). Troque em produção.
ADMIN_EMAIL=admin@agendago.dev
ADMIN_SENHA=troque-esta-senha

# Rate limiting por IP por minuto (0 desliga; sem a variável vale o padrão 10).
# Em dev deixe 0 — os testes e2e fazem dezenas de logins do mesmo IP.
RATE_LIMIT_LOGIN_POR_MINUTO=10
RATE_LIMIT_CONVIDADO_POR_MINUTO=10
