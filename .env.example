# Copie para .env e ajuste os valores. Consumido pelo docker-compose.yml.

# Banco de dados (Postgres)
POSTGRES_DB=agendago
POSTGRES_USER=agendago
POSTGRES_PASSWORD=troque-esta-senha

# Admin semeado no boot da API (moderação). Troque em produção.
ADMIN_EMAIL=admin@agendago.dev
ADMIN_SENHA=troque-esta-senha

# Rate limiting por IP por minuto (0 desliga; sem a variável vale o padrão 10).
# Em dev deixe 0 — os testes e2e fazem dezenas de logins do mesmo IP.
RATE_LIMIT_LOGIN_POR_MINUTO=10
RATE_LIMIT_CONVIDADO_POR_MINUTO=10

# Envio de email (recuperação de senha e notificações de agendamento).
# Em dev os valores abaixo já apontam para o Mailpit do docker-compose
# (UI em http://localhost:8025) — nenhum email real é enviado.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=false
EMAIL_REMETENTE=nao-responda@agendago.dev
EMAIL_REMETENTE_NOME=agendaGo

# Em produção, troque pelas credenciais SMTP do provedor (ex.: Brevo):
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=<login SMTP da conta Brevo>
# SMTP_PASSWORD=<chave SMTP gerada no Brevo>
# SMTP_STARTTLS=true
# EMAIL_REMETENTE=<email verificado no Brevo>
# EMAIL_REMETENTE_NOME=agendaGo
